NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# Free tier at https://finnhub.io/register — used server-side only (app/api/quote)
FINNHUB_API_KEY=

# Free tier at https://twelvedata.com/account/api-keys — used server-side only (app/api/history)
TWELVEDATA_API_KEY=

# Optional — free tier at https://console.upstash.com (Redis). Caches quote/history
# responses (app/api/quote, app/api/history) to cut down on calls to the free-tier
# market data APIs. Without these, the app works the same but without caching.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
