NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# Optional — the project's short ref (the subdomain in its URL above, e.g.
# "xxxxx"). Lets scripts/check-supabase-environment.mjs cross-check against
# supabase/.temp/linked-project.json without parsing the URL. Not read by
# the app itself.
SUPABASE_PROJECT_REF=

# Required before running any migration or regenerating database.types.ts
# against a real project — see docs/supabase-environments.md. Must be
# exactly one of: local, staging, production. Not read by the app itself,
# only by scripts/check-supabase-environment.mjs (npm run check:supabase-env).
# Never set this to "production" for testing/experimentation.
SUPABASE_ENVIRONMENT=local

# Service role key (Supabase dashboard → Settings → API) — server-only, never
# expose with NEXT_PUBLIC_. Used by app/api/account/delete to permanently
# delete a user's auth account (and, via cascade, all their data).
SUPABASE_SERVICE_ROLE_KEY=

# Free tier at https://finnhub.io/register — used server-side only (app/api/quote)
FINNHUB_API_KEY=

# Free tier at https://twelvedata.com/account/api-keys — used server-side only (app/api/history)
TWELVEDATA_API_KEY=

# Optional — free tier at https://console.upstash.com (Redis). Caches quote/history
# responses (app/api/quote, app/api/history) to cut down on calls to the free-tier
# market data APIs. Without these, the app works the same but without caching.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
